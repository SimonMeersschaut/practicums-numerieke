MAXN = 17;
resolution = 10;

f = @(x) exp(x);
derv = @(x) exp(x);
x0 = 1;

SIZE = MAXN * resolution;
eps = zeros(SIZE+1, 1);
h = zeros(SIZE+1, 1);
for n = 0:SIZE
    h(n+1) = 10 ^ (-n/resolution);
    fderx0 = findif(f, h(n+1), x0);
    eps(n+1) = abs(fderx0 - derv(x0));
end

% hold on
loglog(h, eps);
xline(1e-8);
title("Error on derivative");
xlabel("")
% xscale("log");